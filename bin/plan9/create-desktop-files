#!/usr/bin/env rc
. 9.rc

autostart=$home/.config/autostart
mkdir -p $autostart

cat >$autostart/plumber.desktop <<!
[Desktop Entry]
Type=Application
Name=Plumber
TryExec=plumber
Exec=plumber
!

iconsize=128x128
icons=$home/.local/share/icons/hicolor/$iconsize/apps
mkdir -p $icons
convert $PLAN9/mac/spaceglenda.png -resize $iconsize $icons/spaceglenda.png

applications=$home/.local/share/applications
mkdir -p $applications

cat >$applications/9term.desktop <<!
[Desktop Entry]
Type=Application
Name=9term
Icon=spaceglenda
Exec=9term
!

cat >$applications/acme.desktop <<!
[Desktop Entry]
Type=Application
Name=Acme
Icon=spaceglenda
Exec=acme
SingleMainWindow=true
!

cat >$applications/sam.desktop <<!
[Desktop Entry]
Type=Application
Name=Sam
Icon=spaceglenda
Exec=sam
!
